<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Birthday Surprise 🎂</title>

<style>
body{
margin:0;
font-family:Arial, sans-serif;
background:linear-gradient(135deg,#ff9a9e,#fad0c4);
text-align:center;
color:white;
overflow:hidden;
}

h1{
margin-top:30px;
font-size:2.5em;
}

#cake{
width:280px;
margin-top:40px;
transition:0.5s;
}

#candles{
font-size:40px;
margin-top:-40px;
}

button{
padding:12px 20px;
border:none;
border-radius:25px;
font-size:16px;
margin:10px;
background:white;
color:#ff4e75;
cursor:pointer;
}

button:hover{
transform:scale(1.05);
}

#knife{
font-size:40px;
display:none;
margin-top:10px;
}

#message{
display:none;
font-size:28px;
margin-top:20px;
}

.confetti{
position:fixed;
width:10px;
height:10px;
background:white;
top:-10px;
animation:fall linear forwards;
}

@keyframes fall{
to{
transform:translateY(100vh) rotate(720deg);
}
}
</style>
</head>

<body>

<h1>Make a Wish 🎂</h1>

<div id="candles">🕯️🕯️🕯️</div>

<img id="cake" src="https://i.imgur.com/4M7IWwP.png">

<div>
<button onclick="blowCandles()">Blow Candles 💨</button>
</div>

<div id="knife">🔪 Tap the cake to cut</div>

<div id="message">🎉 Happy Birthday! 🎉</div>

<script>

function blowCandles(){
document.getElementById("candles").innerHTML="🕯️🕯️🕯️";
document.getElementById("knife").style.display="block";
}

document.getElementById("cake").onclick=function(){
cutCake();
}

function cutCake(){
document.getElementById("cake").style.transform="scale(0.9) rotate(-5deg)";
document.getElementById("message").style.display="block";
startConfetti();
}

function startConfetti(){

for(let i=0;i<120;i++){

let conf=document.createElement("div");
conf.className="confetti";

conf.style.left=Math.random()*100+"vw";
conf.style.animationDuration=(Math.random()*3+2)+"s";

document.body.appendChild(conf);

setTimeout(()=>{conf.remove()},5000);

}

}

</script>

</body>
</html>
