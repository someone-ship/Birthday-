<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Get Well Soon My Love ❤️💋</title>

<style>
body{
  margin:0;
  font-family:Arial, sans-serif;
  background:linear-gradient(135deg,#ff9a9e,#fad0c4);
  text-align:center;
  color:white;
  overflow:hidden;
}

.container{
  padding:30px;
  margin-top:10vh;
}

h1{
  font-size:36px;
}

p{
  font-size:20px;
}

button{
  background:white;
  color:#ff4d6d;
  border:none;
  padding:14px 22px;
  font-size:18px;
  border-radius:30px;
  cursor:pointer;
  margin:10px;
}

button:hover{
  transform:scale(1.1);
}

#note, #typedLetter, #kisses{
  font-size:22px;
  margin-top:20px;
  min-height:30px;
}

#hug{
  display:none;
  font-size:24px;
  margin-top:20px;
}

#game{
  display:none;
  margin-top:20px;
}

#score{
  font-size:22px;
}

#meter{
  font-size:26px;
  margin-top:20px;
  display:none;
}

.heart, .kiss{
  position:absolute;
  font-size:22px;
  animation:float 6s linear infinite;
}

.kiss{
  font-size:26px;
}

@keyframes float{
  0%{transform:translateY(100vh);}
  100%{transform:translateY(-10vh);}
}
</style>
</head>

<body>

<div class="container">

<h1>Hey My Sick Baby 🤒❤️</h1>

<p>
I know you're not feeling well 🥺<br>
So I made this little website to send you love, hugs, and kisses 💌💋
</p>

<button onclick="showNote()">Open Love Note 💌</button>
<button onclick="sendHug()">Send Virtual Hug 🤗</button>
<button onclick="startGame()">Take Medicine Game 💊</button>
<button onclick="loveMeter()">Love Meter 💖</button>
<button onclick="typeLetter()">Open My Love Letter ✍️</button>
<button onclick="sendKisses()">Lots of Kisses 💋</button>

<div id="note" style="display:none;"></div>
<div id="hug">Huge healing hug sent to you 🤗❤️<br>Get well soon my love.</div>
<div id="game">
  <p>Click the medicine to recover!</p>
  <button onclick="takeMedicine()">💊 Take Medicine</button>
  <p id="score">Health: 0%</p>
</div>
<div id="meter"></div>
<div id="typedLetter" style="display:none;"></div>
<div id="kisses" style="display:none;"></div>

</div>

<audio autoplay loop>
  <source src="https://cdn.pixabay.com/audio/2022/03/15/audio_2a4b5e7c1c.mp3" type="audio/mp3">
</audio>

<script>
// Floating Hearts
function createHeart(){
  const heart=document.createElement("div");
  heart.classList.add("heart");
  heart.innerHTML="❤️";
  heart.style.left=Math.random()*100+"vw";
  heart.style.animationDuration=(3+Math.random()*4)+"s";
  document.body.appendChild(heart);
  setTimeout(()=>heart.remove(),7000);
}
setInterval(createHeart,400);

// Love Notes (fixed)
const notes=[
  "You are the cutest patient ever 😌❤️",
  "Get well soon so I can annoy you again 😏",
  "I wish I could hug you right now 🤗",
  "You mean the world to me 💖",
  "Even sick you are still my favorite person 🥺❤️"
];
function showNote(){
  const noteDiv = document.getElementById("note");
  const randomNote = notes[Math.floor(Math.random()*notes.length)];
  noteDiv.style.display="block"; // make visible
  noteDiv.innerHTML = "💌 "+randomNote;
}

// Virtual Hug
function sendHug(){
  document.getElementById("hug").style.display="block";
}

// Medicine Game
let health=0;
function startGame(){ document.getElementById("game").style.display="block"; }
function takeMedicine(){
  health+=20;
  if(health>100) health=100;
  document.getElementById("score").innerHTML="Health: "+health+"%";
  if(health===100) document.getElementById("score").innerHTML="Health: 100% 🎉 You're healed with love!";
}

// Love Meter
function loveMeter(){
  const meter=document.getElementById("meter");
  meter.style.display="block";
  const love=Math.floor(Math.random()*20)+80;
  meter.innerHTML="Love Meter: "+love+"% ❤️";
}

// Typing Love Letter
const letterLines=[
  "Hey my love 💖,",
  "I know you are not feeling well 😢",
  "I wish I could be there to hug you 🤗",
  "Sending all my love, kisses, and warm cuddles 💌💋",
  "Get well soon, my sweetheart ❤️"
];

function typeLetter(){
  const div = document.getElementById("typedLetter");
  div.style.display="block";
  div.innerHTML="";
  let line=0, charIndex=0;

  function type(){
    if(line>=letterLines.length) return;
    if(charIndex<letterLines[line].length){
      div.innerHTML += letterLines[line][charIndex];
      charIndex++;
      setTimeout(type,70);
    } else {
      div.innerHTML+="<br>";
      line++;
      charIndex=0;
      setTimeout(type,500);
    }
  }
  type();
}

// Kisses
function sendKisses(){
  const div = document.getElementById("kisses");
  div.style.display="block";
  div.innerHTML="Many kisses just for you 💋💋💋💋💋💋💋💋💋💋";
  for(let i=0;i<10;i++){
    const kiss=document.createElement("div");
    kiss.classList.add("kiss");
    kiss.innerHTML="💋";
    kiss.style.left=Math.random()*100+"vw";
    kiss.style.animationDuration=(3+Math.random()*3)+"s";
    document.body.appendChild(kiss);
    setTimeout(()=>kiss.remove(),7000);
  }
}
</script>

</body>
</html>
